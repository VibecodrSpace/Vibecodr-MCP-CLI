{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022", "WebWorker"],
    "rootDir": ".",
    "outDir": "dist-worker"
  },
  "include": [
    "src/hosted/**/*.ts",
    "src/legacy/core/contracts.ts",
    "src/legacy/core/goal-coverage.ts",
    "src/legacy/core/version.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": ["dist", "dist-worker", "node_modules", "test"]
}
